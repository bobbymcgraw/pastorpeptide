---
<Layout title="Links">
  <div class="wrap header">
    <a class="back" href="/seminary">&larr; The Seminary</a>
    <span class="chapter-label">The Church Directory</span>
    <h1>Links</h1>
    <p class="lede">Every vendor, supply shop, and community link the congregation has passed around &mdash; kept current, promo codes stripped out. Nothing here is an endorsement; do your own homework before you spend a dollar.</p>
  </div>

  <div class="wrap groups">
    {sections.map(({ group, note, links }) => (
      <section class="group">
        <h2>{group}</h2>
        {note && <p class="group-note">{note}</p>}
        <ul class="link-list">
          {links.map((l) => (
            <li>
              <a href={l.href} target="_blank" rel="noopener noreferrer nofollow">{l.name}</a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>

<style>
  .header { padding: 40px 20px 24px; }
  .back { color: var(--text-muted); text-decoration: none; font-size: 0.88rem; }
  h1 { margin: 6px 0 6px; }
  .lede { color: var(--text-muted); max-width: 640px; }
  .groups { padding: 0 20px 60px; }
  .group { margin-top: 40px; }
  .group h2 {
    margin-top: 0;
    font-size: 1.15rem;
    color: var(--navy);
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
  }
  .group-note {
    color: var(--text-muted);
    font-size: 0.88rem;
    margin: 8px 0 14px;
  }
  .link-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 6px 20px;
  }
  .link-list li {
    border-bottom: 1px solid var(--border);
  }
  .link-list a {
    display: block;
    padding: 8px 0;
    color: var(--text);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .link-list a:hover {
    color: var(--amber-red);
    text-decoration: underline;
  }
</style>
