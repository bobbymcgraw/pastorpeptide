---
import Layout from './Layout.astro';

interface Props {
  title: string;
  group: string;
  tags?: string[];
  backHref: string;
  backLabel: string;
}
const { title, group, tags = [], backHref, backLabel } = Astro.props;
---
<Layout title={title}>
  <div class="wrap article">
    <a class="back" href={backHref}>&larr; {backLabel}</a>
    <span class="chapter-label">{group}</span>
    <h1>{title}</h1>
    {tags.length > 0 && (
      <div class="tags">
        {tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}
    <div class="prose">
      <slot />
    </div>
  </div>
</Layout>

<style>
  .article {
    padding: 40px 20px 60px;
  }
  .back {
    display: inline-block;
    color: var(--text-muted);
    font-weight: 500;
    text-decoration: none;
    font-size: 0.88rem;
    margin-bottom: 20px;
  }
  h1 {
    margin: 4px 0 8px;
  }
  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 14px 0 8px;
  }
  .tag {
    font-size: 0.75rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 2px 10px;
  }
  .prose {
    margin-top: 28px;
  }
</style>
