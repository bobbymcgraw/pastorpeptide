---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="wrap footer-inner">
    <p><strong>Pastor Peptide</strong> &middot; The Gray Market Study Guide</p>
    <p class="fine">&copy; {year} &mdash; This is not medical advice. Consult a qualified healthcare professional before making decisions about your health.</p>
    <nav>
      <a href="/legal/privacy-policy">Privacy Policy</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: rgba(255,255,255,0.5);
    text-align: center;
    padding: 36px 20px;
    margin-top: 64px;
    font-size: 0.85rem;
  }
  .footer-inner {
    max-width: 740px;
  }
  .site-footer strong {
    color: var(--gold-light);
  }
  .fine {
    margin: 8px 0;
  }
  .footer-inner nav a {
    color: rgba(255,255,255,0.6);
    font-weight: 500;
    text-decoration-color: rgba(255,255,255,0.3);
  }
</style>
